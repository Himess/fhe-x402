{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "."
  },
  "include": [
    "hardhat.config.ts",
    "deploy/**/*.ts",
    "test/**/*.ts",
    "scripts/**/*.ts",
    "tasks/**/*.ts"
  ],
  "files": ["./hardhat.config.ts"]
}
